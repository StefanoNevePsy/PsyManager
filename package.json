{
  "name": "psymanager",
  "version": "1.0.0",
  "description": "Gestionale completo per psicologi e terapeuti - PWA con Capacitor per mobile",
  "homepage": "/PsyManager/",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "cap:add:android": "cap add android",
    "cap:build": "tsc && vite build --mode capacitor",
    "cap:setup:android": "test -d android && bash scripts/setup-android.sh || echo 'android/ not found, skipping setup'",
    "cap:sync": "npm run cap:build && cap sync && npm run cap:setup:android",
    "cap:open:android": "cap open android",
    "android:build": "npm run cap:sync && cap open android"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:36913/git/StefanoNevePsy/PsyManager"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/query-sync-storage-persister": "^5.100.5",
    "@tanstack/react-query": "^5.100.3",
    "@tanstack/react-query-persist-client": "^5.100.5",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-router-dom": "^7.14.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
