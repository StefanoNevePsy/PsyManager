<?xml version="1.0" encoding="utf-8"?>
<!--
    PsyManager adaptive icon foreground.
    The Greek letter Ψ (psi) — symbol of psychology.
    Designed to fit within Android's 72dp safe area inside a 108dp canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:translateX="0"
        android:translateY="0">
        <!-- Left arm of psi -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M28,30 L36,30 L36,55 L28,55 Z" />
        <!-- Right arm of psi -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M72,30 L80,30 L80,55 L72,55 Z" />
        <!-- Center stem of psi (long, extending below the bowl) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M50,30 L58,30 L58,82 L50,82 Z" />
        <!-- Curved bowl connecting all three arms (U-shape) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M28,52 L36,52 C36,62 43,69 54,69 C65,69 72,62 72,52 L80,52 C80,67 68,77 54,77 C40,77 28,67 28,52 Z" />
        <!-- Subtle bottom serif on the stem -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M44,80 L64,80 L64,84 L44,84 Z" />
    </group>
</vector>
