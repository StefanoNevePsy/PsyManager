<?xml version="1.0" encoding="utf-8"?>
<!--
    Only the icon background lives in its own file to avoid clashing with
    Capacitor's default colors.xml (which already defines colorPrimary,
    colorPrimaryDark, colorAccent). This file is copied into
    android/app/src/main/res/values/ic_launcher_background.xml by
    scripts/setup-android.sh and is merged with the rest of values/ at build
    time.
-->
<resources>
    <color name="ic_launcher_background">#1E293B</color>
</resources>
