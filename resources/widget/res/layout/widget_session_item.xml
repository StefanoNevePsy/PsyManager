<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:background="@drawable/widget_item_bg">

    <TextView
        android:id="@+id/item_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:minWidth="48dp"
        android:paddingEnd="10dp"
        android:paddingRight="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/item_patient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFE2E8F0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/item_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF94A3B8"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <ImageView
        android:id="@+id/item_balance_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:src="@drawable/widget_balance_dot"
        android:layout_marginStart="8dp"
        android:layout_marginLeft="8dp"
        android:contentDescription="@string/widget_balance_indicator" />
</LinearLayout>
